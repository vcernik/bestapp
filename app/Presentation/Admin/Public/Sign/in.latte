{block title}Přihlášení{/block}

{block content}
<section class="card border-0 shadow-sm admin-public-box">
	<div class="card-body p-4 p-md-5">
		<h1 class="h3 mb-2">Administrace</h1>
		<p class="text-body-secondary mb-4">Přihlaste se uživatelským jménem a heslem.</p>

		<div n:foreach="$flashes as $flash" class="alert alert-{$flash->type} mb-3" role="alert">{$flash->message}</div>

		{control signInForm}
	</div>
</section>
{/block}
