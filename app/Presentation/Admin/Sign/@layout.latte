{layout '../@layout.base.latte'}

{block body}
	<main class="min-vh-100 d-flex align-items-center py-5">
		<div class="container">
			<div class="row justify-content-center">
				<div class="col-12 col-sm-10 col-md-8 col-lg-5 col-xl-4">
					{include content}
				</div>
			</div>
		</div>
	</main>
{/block}
